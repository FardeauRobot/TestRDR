# Copy this file to ".env" and fill in your Supabase project values to switch
# from Demo mode (single device) to Synced mode (real, cross-device crews).
# Leave the file absent/empty to keep running in Demo mode.
#
# That's all the deployer sets. Crews themselves are created and joined inside
# the app (a name + password), so you do NOT configure crews here.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push (lock-screen SOS alerts). Optional — leave blank to hide the
# "Emergency alerts" toggle. This is the PUBLIC half of a VAPID key pair;
# generate a pair with `npx web-push generate-vapid-keys` and give the PRIVATE
# half to the send-sos edge function (see SETUP-SUPABASE.md).
VITE_VAPID_PUBLIC_KEY=
